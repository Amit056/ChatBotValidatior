{
  "name": "chatbot-validator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
  	"clean:allure": "rimraf allure-results allure-report",
    "test/api": "cross-env ENV=dev npx playwright test",
    "test:dev": "cross-env ENV=dev npx playwright test",
    "test:qa": "cross-env ENV=qa npx playwright test",
    "test:prod": "cross-env ENV=prod npx playwright test",
    "test/e2e": "cross-env ENV=dev playwright test",
    "test/performance": "cross-env ENV=dev k6 run k6-tests/scripts/chatbot.test.ts",
	  "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "pretest:tag": "npm run clean:allure",
    "posttest": "npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "k6-reporter": "github:benc-uk/k6-reporter",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "dotenv": "^17.4.2",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.3",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
